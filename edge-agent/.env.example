# EdgePulse Agent Configurations

# Device Settings
DEVICE_ID=default-device
ENVIRONMENT=production

# API Server Settings
API_PORT=8080
API_HOST=0.0.0.0
API_MODE=auto
API_MIN_MEMORY_MB=512
API_MIN_CPU_CORES=2
API_SOCKET_PATH=/tmp/edgepulse.sock

# Privacy Settings
ANONYMIZATION_LEVEL=medium
COLLECT_COMMAND_LINES=false
DATA_RETENTION_DAYS=30

# Data Collection Settings
COLLECTION_INTERVAL=60
COLLECTION_WINDOW_1MIN=60
COLLECTION_WINDOW_5MIN=300
COLLECTION_WINDOW_15MIN=900
COLLECTION_ENABLE_PROCESS_MONITORING=true
COLLECTION_ENABLE_NETWORK_MONITORING=true
COLLECTION_MAX_PROCESSES=100

# Feature Extraction Settings
FEATURES_FEATURE_DIMENSION=64
FEATURES_HISTORY_RETENTION_HOURS=24
FEATURES_ENABLE_AUTO_SCALING=true
FEATURES_NORMALIZE_FEATURES=true
FEATURES_FEATURE_SELECTION=false

# Detection Settings
DETECTION_THRESHOLD=0.5
DETECTION_USE_AUTOENCODER=false
DETECTION_USE_ENSEMBLE=true
DETECTION_ISOLATION_FOREST_N_ESTIMATORS=100
DETECTION_ISOLATION_FOREST_CONTAMINATION=auto

# Alert Settings
ALERT_ENABLED=true
ALERT_RATE_LIMIT=5
ALERT_RATE_WINDOW=3600
ALERT_CORRELATION_WINDOW=300
ALERT_MIN_SEVERITY=medium
ALERT_ENABLE_LOCAL_NOTIFICATIONS=true

# Sync Settings (Optional)
SYNC_ENABLED=false
SYNC_SUPABASE_URL=
SYNC_SUPABASE_KEY=
SYNC_BATCH_SIZE=50
SYNC_RETRY_MAX_ATTEMPTS=5
SYNC_OFFLINE_QUEUE_MAX=10000
SYNC_SYNC_INTERVAL=300

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_ENABLE_CONSOLE=true

# Metrics Settings
METRICS_ENABLED=true
METRICS_COLLECTION_INTERVAL=30

# Advanced Settings
ENABLE_ML_FEATURES=true
MAX_MEMORY_USAGE_MB=1024
GRACEFUL_SHUTDOWN_TIMEOUT=30
HEALTH_CHECK_INTERVAL=60
