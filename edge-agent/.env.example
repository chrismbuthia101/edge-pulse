# ─── EdgePulse Agent · Environment Configuration ─────────────────────────────

DEVICE_ID=                       
ENVIRONMENT=production

API__PORT=

COLLECTION__INTERVAL=60     
COLLECTION__ENABLE_PROCESS_MONITORING=true
COLLECTION__ENABLE_NETWORK_MONITORING=true

FEATURES__FEATURE_DIMENSION=50    # Must match the pre-trained model's feature dimension
FEATURES__HISTORY_RETENTION_HOURS=24

DETECTION__USE_ENSEMBLE=true
DETECTION__USE_AUTOENCODER=false
DETECTION__ISOLATION_FOREST_N_ESTIMATORS=100
DETECTION__ISOLATION_FOREST_CONTAMINATION=auto

ALERTING__MIN_SEVERITY=medium 
ALERTING__RATE_LIMIT=
ALERTING__RATE_WINDOW=
ALERTING__CORRELATION_WINDOW=300
ALERTING__ENABLE_LOCAL_NOTIFICATIONS=

PRIVACY__DATA_RETENTION_DAYS=30
               
SYNC__BATCH_SIZE=50
SYNC__OFFLINE_QUEUE_MAX=10000
SYNC__RETRY_MAX_ATTEMPTS=5

LOG__LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL

METRICS__COLLECTION_INTERVAL=30

HEALTH_CHECK_INTERVAL=60