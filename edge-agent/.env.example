# ─── EdgePulse Agent · Environment Configuration ─────────────────────────────
# Copy to .env and fill in values. All settings have safe defaults.
# Nested keys use double-underscore: API__PORT, SYNC__SUPABASE_URL, etc.

# ─── Device ───────────────────────────────────────────────────────────────────
DEVICE_ID=                        # Auto-generated from hostname if blank
ENVIRONMENT=production            # development | staging | production

# ─── API Server ───────────────────────────────────────────────────────────────
API__PORT=8080
API__MODE=auto                    # auto | fastapi | minimal | socket
API__MIN_MEMORY_MB=512            # Threshold to pick FastAPI over minimal server
API__MIN_CPU_CORES=2
API__SOCKET_PATH=/tmp/edgepulse.sock

# ─── Data Collection ──────────────────────────────────────────────────────────
COLLECTION__INTERVAL=60           # Seconds between telemetry cycles (5–3600)
COLLECTION__ENABLE_PROCESS_MONITORING=true
COLLECTION__ENABLE_NETWORK_MONITORING=true
COLLECTION__MAX_PROCESSES=100

# ─── Feature Extraction ───────────────────────────────────────────────────────
FEATURES__FEATURE_DIMENSION=50    # Must match bootstrap_model.py FEATURE_DIMENSION
FEATURES__HISTORY_RETENTION_HOURS=24
FEATURES__NORMALIZE_FEATURES=true

# ─── Anomaly Detection ────────────────────────────────────────────────────────
DETECTION__THRESHOLD=0.5
DETECTION__USE_ENSEMBLE=true
DETECTION__USE_AUTOENCODER=false
DETECTION__ISOLATION_FOREST_N_ESTIMATORS=100
DETECTION__ISOLATION_FOREST_CONTAMINATION=auto

# ─── Alerting ─────────────────────────────────────────────────────────────────
ALERTING__ENABLED=true
ALERTING__MIN_SEVERITY=medium     # low | medium | high | critical
ALERTING__RATE_LIMIT=5            # Max alerts per rate window
ALERTING__RATE_WINDOW=3600        # Seconds
ALERTING__CORRELATION_WINDOW=300  # Seconds — groups related alerts
ALERTING__ENABLE_LOCAL_NOTIFICATIONS=true

# ─── Privacy ──────────────────────────────────────────────────────────────────
PRIVACY__DATA_RETENTION_DAYS=30
PRIVACY__ANONYMIZATION_LEVEL=basic   # none | basic | medium | full
PRIVACY__COLLECT_COMMAND_LINES=false

# ─── Cloud Sync (optional) ────────────────────────────────────────────────────
SYNC__ENABLED=false
SYNC__SUPABASE_URL=               # https://your-project.supabase.co
SYNC__SUPABASE_KEY=               # Service-role or device API key
SYNC__BATCH_SIZE=50
SYNC__OFFLINE_QUEUE_MAX=10000
SYNC__RETRY_MAX_ATTEMPTS=5
SYNC__SYNC_INTERVAL=300

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG__LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG__FORMAT=json                  # json | text
LOG__ENABLE_CONSOLE=true

# ─── Metrics ──────────────────────────────────────────────────────────────────
METRICS__ENABLED=true
METRICS__COLLECTION_INTERVAL=30

# ─── Advanced ─────────────────────────────────────────────────────────────────
ENABLE_ML_FEATURES=true
MAX_MEMORY_USAGE_MB=1024
GRACEFUL_SHUTDOWN_TIMEOUT=30
HEALTH_CHECK_INTERVAL=60