# EdgePulse Configuration Template
# Copy this file to .env and fill in your values

# Device Identification
DEVICE_ID=your-device-id-here
DEVICE_NAME=your-device-name

# Supabase Configuration (Optional - for cloud sync)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_ENABLED=false

# Detection Settings
DETECTION_THRESHOLD=0.5
ISOLATION_FOREST_CONTAMINATION=auto
ISOLATION_FOREST_N_ESTIMATORS=100

# Collection Settings
COLLECTION_INTERVAL=5
FEATURE_WINDOW_1MIN=60
FEATURE_WINDOW_5MIN=300
FEATURE_WINDOW_15MIN=900

# Privacy Settings
DATA_RETENTION_DAYS=30
ANONYMIZATION_LEVEL=strict
COLLECT_COMMAND_LINES=false

# Alerting Settings
ALERT_CORRELATION_WINDOW=300
ALERT_RATE_LIMIT=10
ALERT_RATE_WINDOW=3600
MIN_SEVERITY_FOR_ALERT=medium

# Sync Settings
SYNC_ENABLED=false
SYNC_INTERVAL=3600
SYNC_ONLY_ALERTS=true

# Logging Settings
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=90

# Paths (relative to edge-agent directory)
DATA_DIR=./data
MODELS_DIR=./models
LOGS_DIR=./data/logs
CACHE_DIR=./data/cache
CONFIG_DIR=~/.edge-pulse
